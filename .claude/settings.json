{
  "env": {
    "CLAUDE_CODE_TMPDIR": ".claude/tmp"
  },
  "permissions": {
    "allow": [
      "Bash(cat:*)",
      "WebFetch(domain:api.jolpi.ca)",
      "mcp__github__add_reply_to_pull_request_comment",
      "Bash(cd:*)",
      "Bash(echo:*)",
      "mcp__github__list_pull_requests",
      "mcp__github__pull_request_read",
      "Bash(./gradlew build:*)",
      "Bash(./gradlew :use-case:compileKotlin:*)",
      "Bash(./gradlew :jolpica:detekt:*)",
      "Bash(./gradlew test:*)",
      "Bash(./gradlew detekt:*)",
      "Bash(wc:*)",
      "Bash(./gradlew :scheduled:detekt:*)",
      "Bash(./gradlew :scheduled:test:*)",
      "mcp__postgres__query",
      "Bash(jar tf:*)",
      "Bash(./gradlew :db:test:*)",
      "Bash(./gradlew :app:test:*)",
      "Bash(./gradlew :jolpica:test:*)",
      "Bash(gunzip:*)",
      "Bash(gzip -dk logs/*.gz 2>&1)",
      "Bash(curl:*)",
      "mcp__plugin_playwright_playwright__browser_click",
      "mcp__plugin_playwright_playwright__browser_navigate",
      "mcp__plugin_playwright_playwright__browser_take_screenshot",
      "mcp__plugin_playwright_playwright__browser_snapshot",
      "mcp__plugin_playwright_playwright__browser_select_option",
      "mcp__plugin_playwright_playwright__browser_evaluate",
      "mcp__plugin_playwright_playwright__browser_press_key",
      "mcp__plugin_playwright_playwright__browser_wait_for",
      "mcp__postgres__query",
      "Bash(pip install:*)",
      "Bash(where python:*)",
      "Bash(netstat:*)",
      "Bash(python:*)",
      "Bash(ls:*)"
    ],
    "deny": [
      "Read(.env)",
      "Read(.env.*)",
      "Read(**/secrets.yml)",
      "Read(**/secrets.yaml)",
      "Read(dev-secrets.properties)",
      "Edit(.env)",
      "Edit(.env.*)",
      "Edit(**/secrets.yml)",
      "Edit(**/secrets.yaml)",
      "Edit(dev-secrets.properties)"
    ]
  },
  "enabledPlugins": {
    "typescript-lsp@claude-plugins-official": true,
    "pyright-lsp@claude-plugins-official": true,
    "jdtls-lsp@claude-plugins-official": true,
    "kotlin-lsp@claude-plugins-official": true,
    "frontend-design@claude-plugins-official": true,
    "context7@claude-plugins-official": true,
    "feature-dev@claude-plugins-official": true,
    "code-simplifier@claude-plugins-official": true,
    "claude-code-setup@claude-plugins-official": true,
    "pr-review-toolkit@claude-plugins-official": true,
    "playwright@claude-plugins-official": true
  },
  "language": "russian",
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/format-python.sh"
          },
          {
            "type": "command",
            "command": "bash .claude/hooks/format-typescript.sh"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Write",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/guard-migration.sh"
          }
        ]
      }
    ]
  }
}
